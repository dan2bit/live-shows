# Credentials for the live-shows tools/youtube scripts
# ----------------------------------------------------
# Copy this file to .env in the SAME directory as the scripts (tools/youtube/) and fill in your values.
# .env is gitignored at any depth and must never be committed.
#
# GitHub tokens are NOT configured here — see docs/FORK_SETUP.md, and keep them in your password manager.

# YouTube Data API key (read-only; used by youtube_fetch.py)
# Get from: Google Cloud Console → APIs & Services → Credentials → API Keys
YOUTUBE_API_KEY=your_api_key_here

# OAuth client secrets file (used by the write scripts: youtube_create_playlists.py,
# youtube_fix_descriptions.py, youtube_fill_handles.py)
# Download from: Google Cloud Console → Credentials → OAuth 2.0 Client IDs
# Use a BARE filename (no path) — it is resolved relative to the script's own directory.
YOUTUBE_CLIENT_SECRETS=client_secrets.json

# OAuth token cache file (auto-generated on first auth run — do not edit manually)
# Bare filename, same rule as above.
YOUTUBE_TOKEN_FILE=token.json

# Spotify API credentials (used by youtube_fill_handles.py)
# Create a free app at: https://developer.spotify.com/dashboard
# Set any Redirect URI (e.g. http://localhost) — it is not used by this script.
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
