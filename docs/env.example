# Credentials for the live-shows helper scripts
# -----------------------------------------------
# Copy this file to .env in the SAME directory as the script that needs it, and fill
# in your values. .env is gitignored at any depth and must never be committed.
#
# Two scripts read a .env, each from its OWN directory (load_dotenv resolves relative
# to the script), so a fork typically keeps two copies of the relevant lines:
#   tools/youtube/.env   -> the YouTube scripts (youtube_fetch.py, youtube_create_playlists.py,
#                           youtube_fix_descriptions.py, youtube_fill_handles.py)
#   scripts/.env         -> spotify_cache.py (the Spotify/Last.fm artist-enrichment cache)
# The Spotify client id/secret are used by BOTH; LASTFM_API_KEY is used only by scripts/.env.
#
# GitHub tokens are NOT configured here -- see docs/FORK_SETUP.md, and keep them in your password manager.

# YouTube Data API key (read-only; used by youtube_fetch.py)
# Get from: Google Cloud Console -> APIs & Services -> Credentials -> API Keys
YOUTUBE_API_KEY=your_api_key_here

# OAuth client secrets file (used by the write scripts: youtube_create_playlists.py,
# youtube_fix_descriptions.py, youtube_fill_handles.py)
# Download from: Google Cloud Console -> Credentials -> OAuth 2.0 Client IDs
# Use a BARE filename (no path) -- it is resolved relative to the script's own directory.
YOUTUBE_CLIENT_SECRETS=client_secrets.json

# OAuth token cache file (auto-generated on first auth run -- do not edit manually)
# Bare filename, same rule as above.
YOUTUBE_TOKEN_FILE=token.json

# Spotify API credentials
#   - youtube_fill_handles.py (tools/youtube/.env)
#   - spotify_cache.py        (scripts/.env)
# Create a free app at: https://developer.spotify.com/dashboard
# Set any Redirect URI (e.g. http://127.0.0.1:8888/callback) -- not used by these read-only scripts.
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Last.fm API key (used by spotify_cache.py -- scripts/.env only)
# The artist-enrichment layer's only credential: tags, listener counts, similar-artist
# graph, and mbid that feed data/artist_spotify.json.
# Get a free key from: https://www.last.fm/api/account/create
LASTFM_API_KEY=your_lastfm_api_key_here
